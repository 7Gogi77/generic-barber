{
  "buildCommand": "echo 'Static build complete'",
  "devCommand": "npx http-server . -p 3000",
  "installCommand": "npm install",
  "framework": null,
  "public": true,
  "git": {
    "deploymentEnabled": true
  },
  "functions": {
    "api/schedule.js": {
      "runtime": "nodejs18.x",
      "memory": 128,
      "maxDuration": 10
    }
  },
  "env": {
    "KV_URL": "@kv_url",
    "KV_REST_API_TOKEN": "@kv_rest_api_token"
  },
  "crons": [],
  "ignoreCommand": "git diff --quiet HEAD~1 HEAD -- . ':(exclude)README.md'",
  "regions": ["iad1"],
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)?",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    }
  ]
}
